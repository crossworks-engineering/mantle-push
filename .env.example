# Mantle Push — relay configuration.
# Copy to .env for local dev. Secrets (.p8 key, FCM JSON) never go in git.

# HTTP
PORT=8787

# Postgres (its own DB, isolated from the Mantle "brain" DB)
DATABASE_URL=postgres://push:push@localhost:5544/mantle_push

# Push provider: "mock" (default — logs deliveries, no creds needed, for local
# CLI verification) | "live" (uses the APNs/FCM credentials below).
PUSH_PROVIDER=mock

# The app's bundle id / APNs topic. One value for the single store app.
# Registered bundle id (Apple App ID) — must match exactly or APNs 400s.
APNS_TOPIC=crossworks.engineering.mantle

# --- APNs (Apple) — required when PUSH_PROVIDER=live ---
# Token-based auth (.p8). https://developer.apple.com/account → Keys.
APNS_KEY_ID=
APNS_TEAM_ID=
# Path to the .p8 file, OR inline PEM in APNS_KEY_P8 (multiline).
APNS_KEY_PATH=./secrets/AuthKey.p8
APNS_KEY_P8=
# "production" | "sandbox" (sandbox for development builds / TestFlight debug)
APNS_ENV=sandbox

# --- FCM (Google) — required when PUSH_PROVIDER=live for Android ---
# A service-account JSON. Path OR inline JSON in FCM_SERVICE_ACCOUNT.
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_PATH=./secrets/fcm-service-account.json
FCM_SERVICE_ACCOUNT=

# Rate limits (per instance, sliding window). Tune for cost control.
RATE_NOTIFY_PER_MIN=60
RATE_ENROLL_PER_MIN=10
